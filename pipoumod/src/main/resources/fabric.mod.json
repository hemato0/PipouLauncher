	"authors": ["Matheo"],
	"license": "MIT",
	"environment": "client",
	"entrypoints": {
		"client": ["com.pipou.pipoumod.PipouModClient"]
	},
	"mixins": ["pipoumod.mixins.json"],
	"depends": {
		"fabricloader": ">=0.16.0",
		"minecraft": "${mcdep}",
		"java": "${javadep}",
		"fabric-api": "*"
	}
}
