{
  "name": "perf-launcher",
  "version": "0.1.20",
  "description": "PipouLauncher 💜 — launcher Minecraft d'optimisation (rose & violet, cœurs partout).",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish never",
    "publish": "electron-builder --publish always"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "electron-updater": "^6.8.9",
    "systeminformation": "^5.22.0"
  },
  "build": {
    "appId": "com.pipou.pipoulauncher",
    "productName": "PipouLauncher",
    "artifactName": "PipouLauncher-Setup-${version}.${ext}",
    "afterPack": "build/afterPack.js",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PipouLauncher",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "hemato0",
        "repo": "PipouLauncher",
        "releaseType": "release"
      }
    ]
  }
}
